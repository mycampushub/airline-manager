{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "src/app/api",
    "src/app/layout.tsx",
    "src/app/page.tsx",
    "src/lib/db.ts",
    "src/lib/engines/availability-engine.ts",
    "src/lib/engines/baggage-engine.ts",
    "src/lib/engines/boarding-engine.ts",
    "src/lib/engines/commission-engine.ts",
    "src/lib/engines/crew-compliance-engine.ts",
    "src/lib/engines/flight-ops-engine.ts",
    "src/lib/engines/loadbalance-engine.ts",
    "src/lib/engines/pnr-engine.ts",
    "src/lib/engines/pricing-engine.ts",
    "src/lib/engines/settlement-engine.ts",
    "src/lib/engines/tax-engine.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
